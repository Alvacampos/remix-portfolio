{
  "name": "remix-portfolio",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production react-router build",
    "build:svg": "svgo -f ./app/assets/icons",
    "build:icons": "npx @svgr/cli --config-file ./svgr.config.cjs -- ./app/assets/icons",
    "build:og": "node scripts/render-og-image.mjs",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "lint": "run-s lint:*",
    "lint:css": "stylelint 'app/**/*.css'",
    "lint:es": "eslint --color .",
    "lint:ls": "npx @ls-lint/ls-lint",
    "lint:prettier": "npx prettier --check .",
    "start": "wrangler dev",
    "typecheck": "tsc",
    "typegen": "wrangler types",
    "preview": "npm run build && wrangler dev",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test visual.spec.ts --project=chromium --project=mobile",
    "test:visual:update": "scripts/update-visual-baselines.sh",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "scripts/pre-push.sh"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "isbot": "^5.2.0",
    "postcss-extend-rule": "^4.0.0",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^10.1.14",
    "react-router": "^8.2.0",
    "react-vertical-timeline-component": "^4.0.0",
    "svgo": "^4.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^9.39.5",
    "@ls-lint/ls-lint": "^2.3.1",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^8.2.0",
    "@react-router/fs-routes": "^8.2.0",
    "@size-limit/preset-app": "^12.1.0",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@svgr/cli": "^8.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.5.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.6",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.48.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

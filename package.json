{
  "name": "remix-portfolio",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production remix vite:build",
    "build:svg": "svgo -f ./app/assets/icons",
    "build:icons": "npx @svgr/cli --config-file ./svgr.config.cjs -- ./app/assets/icons",
    "deploy": "npm run build && wrangler pages deploy",
    "dev": "remix vite:dev",
    "lint": "run-s lint:*",
    "lint:es": "eslint --ext .js,.jsx,.ts,.tsx --color ./",
    "lint:ls": "npx @ls-lint/ls-lint",
    "lint:prettier": "npx prettier --check .",
    "start": "wrangler pages dev ./build/client",
    "typecheck": "tsc",
    "typegen": "wrangler types",
    "preview": "npm run build && wrangler pages dev",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@remix-run/cloudflare": "^2.17.5",
    "@remix-run/cloudflare-pages": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "cssnano": "^7.1.9",
    "date-fns": "^4.4.0",
    "eslint": "^8.57.0",
    "isbot": "^5.1.43",
    "postcss-extend-rule": "^4.0.0",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intl": "^7.1.14",
    "react-is": "^19.2.7",
    "react-vertical-timeline-component": "^4.0.0",
    "recharts": "^3.8.1",
    "remix-utils": "^7.7.0",
    "svgo": "^4.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@cloudflare/workers-types": "^4.20260616.1",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^8.57.0",
    "@ls-lint/ls-lint": "^2.3.1",
    "@playwright/test": "^1.61.0",
    "@remix-run/dev": "^2.17.5",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@svgr/cli": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@vitest/ui": "^3.2.6",
    "autoprefixer": "^10.5.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^16.4.0",
    "happy-dom": "^20.10.4",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.0",
    "postcss": "^8.5.6",
    "postcss-mixins": "^12.1.2",
    "prettier": "^3.8.4",
    "react-router-dom": "6.30.4",
    "storybook": "^10.4.6",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.1",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6",
    "wrangler": "^4.101.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}

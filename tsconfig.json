{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx"
  ],
  // `.react-router/` is auto-generated by `react-router typegen` +
  // build; useful only if we opt into the Route.LoaderArgs pattern
  // (Phase C of the migration). Excluded for now — the .js-suffixed
  // imports in the generated files don't resolve under the current
  // moduleResolution setting, and the current `useLoaderData<typeof
  // loader>()` API doesn't need those types.
  "exclude": ["node_modules", "build", ".wrangler", ".react-router"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client", "@cloudflare/workers-types/2023-07-01"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "~data/*": ["./public/data/*"]
    },

    // Vite takes care of building everything, not tsc.
    "noEmit": true
  }
}

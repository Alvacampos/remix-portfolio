{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx"
  ],
  // `.react-router/` is auto-generated by `react-router typegen` +
  // build; the generated `+types/*.ts` files use `.js` import
  // extensions (`typeof import("../index.js")`) that tsc doesn't
  // rewrite under `moduleResolution: Bundler` + `noEmit`. Since we
  // don't currently opt into the `Route.LoaderArgs` pattern (our
  // loaders don't emit Date/Map/undefined so the classic
  // `useLoaderData<typeof loader>()` typing is accurate), we exclude
  // the generated types to keep tsc quiet.
  "exclude": ["node_modules", "build", ".wrangler", ".react-router"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client", "@cloudflare/workers-types/2023-07-01"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    // No `baseUrl` — deprecated in TS 6, removal in 7. `paths` resolves
    // relative to this tsconfig.json without it (has since TS 4.1).
    "paths": {
      "~/*": ["./app/*"],
      "~data/*": ["./public/data/*"]
    },

    // Vite takes care of building everything, not tsc.
    "noEmit": true
  }
}
